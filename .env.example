# API-Football (API-Sports)
# Put real secrets in .env.local (never commit .env.local)
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=
API_FOOTBALL_SEASON=2026

# Toggle real provider usage. Keep false for demos/safe local runs.
NEXT_PUBLIC_USE_REAL_FOOTBALL_DATA=false

# WordPress FIFApp API (Auth, Products, Purchases)
NEXT_PUBLIC_WP_API_URL=https://tudominio.com/wp-json/fifapp/v1
